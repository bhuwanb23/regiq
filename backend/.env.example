# REGIQ Backend - Example Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development  # development | staging | production

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:19000,http://localhost:19002,http://localhost:8081,http://localhost:3000

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=regiq_backend
DB_USER=regiq_user
DB_PASSWORD=your_secure_password_here
DB_DIALECT=postgres

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Change these in production!
JWT_SECRET=change_this_to_a_random_secure_string_in_production
JWT_REFRESH_SECRET=change_this_to_another_random_secure_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info  # debug | info | warn | error

# ============================================
# API Keys
# ============================================
API_KEY_HEADER=X-API-Key

# ============================================
# AI/ML Service Configuration
# ============================================
AI_ML_SERVICE_BASE_URL=http://localhost:8000
AI_ML_SERVICE_API_KEY=regiq-internal-api-key
AI_ML_SERVICE_TIMEOUT=60000
AI_ML_SERVICE_MAX_RETRIES=3

# Individual AI/ML endpoint overrides (optional)
COMPLIANCE_MODEL_ENDPOINT=/api/v1/regulatory-intelligence/documents/analyze
RISK_MODEL_ENDPOINT=/api/v1/risk-simulator/simulate
BIAS_ANALYZE_ENDPOINT=/api/v1/bias-analysis/analyze
BIAS_SCORE_ENDPOINT=/api/v1/bias-analysis/score
REPORT_GENERATE_ENDPOINT=/api/v1/report-generator/generate

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_ITEMS=1000

# ============================================
# Rate Limiting
# ============================================
RATE_LIMITING_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Job Queue
# ============================================
JOB_QUEUE_CONCURRENCY=5
JOB_QUEUE_TIMEOUT=60000
JOB_QUEUE_RETRY_DELAY=5000
JOB_QUEUE_MAX_RETRIES=3

# ============================================
# Monitoring
# ============================================
MONITORING_ENABLED=true
MONITORING_LOG_LEVEL=info
